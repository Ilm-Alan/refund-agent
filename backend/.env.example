# The agent targets the Anthropic Messages API as its provider contract.
# Any Anthropic-compatible endpoint works; pick ONE block below.
# The client is constructed with no credential or endpoint arguments, so
# switching providers is purely an .env change.

# --- Ollama Cloud (free) ---
ANTHROPIC_BASE_URL=https://ollama.com
ANTHROPIC_AUTH_TOKEN=            # your Ollama API key (sent as a Bearer token)
AGENT_MODEL=glm-5.2

# --- Ollama local ---
# ANTHROPIC_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=ollama       # required by the SDK, ignored by Ollama
# AGENT_MODEL=qwen3-coder

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=             # https://platform.claude.com
# AGENT_MODEL=claude-sonnet-5

# --- Voice (optional) ---
# The voice pipeline activates when OPENAI_API_KEY is set. Any
# OpenAI-compatible audio endpoint works; leave OPENAI_BASE_URL unset for
# OpenAI itself.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# STT_MODEL=gpt-4o-mini-transcribe
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=nova
